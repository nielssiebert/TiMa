FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

ARG VITE_APP_TITLE=TiMa
ARG VITE_APP_PROFILE=production
ARG VITE_PUBLIC_BASE_PATH=/
ARG VITE_API_BASE_URL=/api
ARG VITE_OVERVIEW_REFRESH_DEFAULT_MS=5000
ARG VITE_OVERVIEW_REFRESH_EXECUTION_EVENTS_MS=1000
ARG VITE_OVERVIEW_REFRESH_SEQUENCES_MS=2000

RUN VITE_APP_TITLE="$VITE_APP_TITLE" \
    VITE_APP_PROFILE="$VITE_APP_PROFILE" \
    VITE_PUBLIC_BASE_PATH="$VITE_PUBLIC_BASE_PATH" \
    VITE_API_BASE_URL="$VITE_API_BASE_URL" \
    VITE_OVERVIEW_REFRESH_DEFAULT_MS="$VITE_OVERVIEW_REFRESH_DEFAULT_MS" \
    VITE_OVERVIEW_REFRESH_EXECUTION_EVENTS_MS="$VITE_OVERVIEW_REFRESH_EXECUTION_EVENTS_MS" \
    VITE_OVERVIEW_REFRESH_SEQUENCES_MS="$VITE_OVERVIEW_REFRESH_SEQUENCES_MS" \
    npm run build-only
